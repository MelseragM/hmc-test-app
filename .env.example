# HTTP port the app listens on
PORT=3000

# Google Cloud service account credentials used by @google-cloud/vision
GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/google-service-account.json"

# OCR engine to use: paddle or google
OCR_PROVIDER=paddle

# Self-hosted PaddleOCR HTTP endpoint. The endpoint should accept multipart
# form-data with a file field and return raw text, { "text": "..." }, or
# { "result": [{ "text": "..." }] }.
PADDLE_OCR_URL="http://localhost:8000/ocr"
PADDLE_OCR_FILE_FIELD=file

# Maximum OCR upload size in megabytes
OCR_MAX_FILE_SIZE_MB=5
